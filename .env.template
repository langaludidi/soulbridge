# SoulBridge Environment Configuration Template
# Fill in your actual values and rename this file to .env

# ===========================================
# SUPABASE DATABASE CONNECTION
# ===========================================
# Get this from: https://supabase.com/dashboard/project/jjuwdplambkndelfyjcy/settings/database
# Copy the "URI" connection string and paste it below:

SUPABASE_DB_URL="PASTE_YOUR_CONNECTION_STRING_HERE"

# Alternative format (you can use either SUPABASE_DB_URL or DATABASE_URL):
# DATABASE_URL="PASTE_YOUR_CONNECTION_STRING_HERE"

# ===========================================
# SUPABASE API CONFIGURATION (OPTIONAL)
# ===========================================
# Get these from: https://supabase.com/dashboard/project/jjuwdplambkndelfyjcy/settings/api

SUPABASE_URL="https://jjuwdplambkndelfyjcy.supabase.co"
SUPABASE_ANON_KEY="PASTE_YOUR_ANON_KEY_HERE"
SUPABASE_SERVICE_ROLE_KEY="PASTE_YOUR_SERVICE_ROLE_KEY_HERE"

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

APP_URL="http://localhost:5000"
NODE_ENV="development"

# Generate a secure random string for session secret:
SESSION_SECRET="your_secure_session_secret_here"

# ===========================================
# PAYMENT INTEGRATION (REQUIRED FOR PAYMENTS)
# ===========================================

PAYSTACK_SECRET_KEY="your_paystack_secret_key_here"
PAYSTACK_PUBLIC_KEY="your_paystack_public_key_here"
PAYSTACK_WEBHOOK_SECRET="your_paystack_webhook_secret_here"

# Client-side Paystack key (same as PAYSTACK_PUBLIC_KEY):
REACT_APP_PAYSTACK_PUBLIC_KEY="your_paystack_public_key_here"

# ===========================================
# OPTIONAL: NETCASH INTEGRATION
# ===========================================

# NETCASH_SERVICE_KEY="your_netcash_service_key_here"
# NETCASH_MERCHANT_EMAIL="your_netcash_merchant_email_here"

# ===========================================
# REPLIT AUTHENTICATION (AUTO-SET BY REPLIT)
# ===========================================

