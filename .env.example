# Environment Configuration for SoulBridge Application

# Database Configuration
# Choose ONE of the following database configuration options:

# Option 1: Direct PostgreSQL connection (Neon, Railway, etc.)
DATABASE_URL="your_postgres_connection_string_here"

# Option 2: Supabase Database Connection (Direct URL)
# Get this from: Supabase Dashboard > Settings > Database > Connection string > URI
# SUPABASE_DB_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Option 3: Supabase Individual Connection Parameters
# SUPABASE_HOST="[YOUR-PROJECT-REF].supabase.co"
# SUPABASE_PASSWORD="your_supabase_database_password"
# SUPABASE_DATABASE="postgres"
# SUPABASE_USER="postgres"
# SUPABASE_PORT="5432"

# Supabase API Configuration (Optional - for real-time features, auth, etc.)
# Get these from: Supabase Dashboard > Settings > API
# SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# SUPABASE_ANON_KEY="your_supabase_anon_key_here"
# SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# Application Configuration
APP_URL="https://yourdomain.com"
# For development: APP_URL="http://localhost:5000"
# For production: APP_URL="https://soulbridge.co.za"

# NetCash Pay Now Integration
# Get these values from your NetCash merchant account > NetConnector > Pay Now settings
NETCASH_SERVICE_KEY="your_netcash_service_key_here"
NETCASH_MERCHANT_EMAIL="your_netcash_merchant_email_here"

# Paystack Integration (Required for payments)
PAYSTACK_SECRET_KEY="your_paystack_secret_key_here"
PAYSTACK_PUBLIC_KEY="your_paystack_public_key_here"
PAYSTACK_WEBHOOK_SECRET="your_paystack_webhook_secret_here"

# Client-side Paystack Public Key (for react-paystack)
REACT_APP_PAYSTACK_PUBLIC_KEY="your_paystack_public_key_here"

# Session Secret (generate a secure random string)
SESSION_SECRET="your_secure_session_secret_here"

# Environment
NODE_ENV="production"

# Replit Authentication (automatically set by Replit)
# REPLIT_DB_URL (set automatically)