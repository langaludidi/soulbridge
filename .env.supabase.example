SUPABASE_DB_URL="postgresql://postgres:[YOUR-DATABASE-PASSWORD]@db.jjuwdplambkndelfyjcy.supabase.co:5432/postgres"

# Option 2: Individual Parameters (Alternative)
# SUPABASE_HOST="db.jjuwdplambkndelfyjcy.supabase.co"
# SUPABASE_PASSWORD="[YOUR-DATABASE-PASSWORD]"
# SUPABASE_DATABASE="postgres"
# SUPABASE_USER="postgres"
# SUPABASE_PORT="5432"

# ===========================================
# OPTIONAL: Supabase API Configuration
# ===========================================
# Get these from: Supabase Dashboard > Settings > API
# Needed for real-time features, auth, and client-side operations

SUPABASE_URL="https://jjuwdplambkndelfyjcy.supabase.co"
SUPABASE_ANON_KEY="[YOUR-ANON-KEY-FROM-SUPABASE-DASHBOARD]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY-FROM-SUPABASE-DASHBOARD]"

# ===========================================
# Existing SoulBridge Configuration
# ===========================================

# Application Configuration
APP_URL="https://yourdomain.com"
NODE_ENV="production"

# Session Secret (generate a secure random string)
SESSION_SECRET="your_secure_session_secret_here"

# Paystack Integration (Required for payments)
PAYSTACK_SECRET_KEY="your_paystack_secret_key_here"
PAYSTACK_PUBLIC_KEY="your_paystack_public_key_here"
PAYSTACK_WEBHOOK_SECRET="your_paystack_webhook_secret_here"

# Client-side Paystack Public Key (for react-paystack)
REACT_APP_PAYSTACK_PUBLIC_KEY="your_paystack_public_key_here"

# NetCash Pay Now Integration (Optional)
NETCASH_SERVICE_KEY="your_netcash_service_key_here"
NETCASH_MERCHANT_EMAIL="your_netcash_merchant_email_here"

# Replit Authentication (if using Replit deployment)
# These are automatically set by Replit
# REPL_ID="your-repl-id"
# REPLIT_DOMAINS="your-repl-domain.repl.co"